# POSTGRES_HOST
# For MAC 0.0.0.0
# For WIN localhost
# For Docker "database"
POSTGRES_HOST=0.0.0.0
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aura_spa
PORT=3100
NODE_ENV="development"
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Mail driver:
# - console logs OTP codes in backend logs for local development/demo without a mail domain
# - resend sends real OTP emails via Resend and requires a verified sending domain
MAIL_DRIVER=console

# Resend (used when MAIL_DRIVER=resend — https://resend.com)
RESEND_API_KEY=re_QoopYuar_5yzKUJtwSAvvEpaW9SzJQ2n6
MAIL_FROM=no-reply@marketonl.site
MAIL_FROM_NAME="Aura Spa" 

# Google OAuth2 (used for Google login — https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3100/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Default password assigned to new staff accounts created by a branch manager
DEFAULT_STAFF_PASSWORD=Staff@123!
