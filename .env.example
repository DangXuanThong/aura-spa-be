# POSTGRES_HOST
# For MAC 0.0.0.0
# For WIN localhost
# For Docker "database"
POSTGRES_HOST=0.0.0.0
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aura_spa
PORT=3100
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<your-rsa-private-key-here>\n-----END RSA PRIVATE KEY-----\n"
PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<your-rsa-public-key-here>\n-----END PUBLIC KEY-----\n"
NODE_ENV="development"
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Resend (used for OTP verification emails — https://resend.com)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME="Aura Spa"
