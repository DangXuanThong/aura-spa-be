# ── Server ────────────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=development
# NODE_ENV=production  ← set this in deployment; controls CORS restrictions and Swagger visibility

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev: localhost | For Docker Compose local DB: database | For Neon: your .neon.tech host
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_NAME=aura_spa
# POSTGRES_SSL=true   enable for managed cloud databases. Neon hosts enable SSL automatically.

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production: generate with `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
DEFAULT_STAFF_PASSWORD=ChangeMe123!

# ── Mail ──────────────────────────────────────────────────────────────────────
# console: logs to stdout (local dev only — no real email sent)
# resend:  sends real emails via Resend (requires RESEND_API_KEY + verified domain)
MAIL_DRIVER=console
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME='Aura Spa'

# ── SePay deposit payments ─────────────────────────────────────────────────
SEPAY_WEBHOOK_SECRET=change-me
SEPAY_BANK_ACCOUNT=0000000000
SEPAY_BANK_CODE=Vietcombank
SEPAY_PAYMENT_CODE_PREFIX=ABK
BOOKING_DEPOSIT_PERCENT=30
BOOKING_DEPOSIT_EXPIRE_MINUTES=15

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3100/auth/google/callback

# ── Seeding ───────────────────────────────────────────────────────────────────
# SKIP_SEED=true — skip onApplicationBootstrap seeders (use when DB already seeded / QA).
# SKIP_SEED=false

# ── Aura AI (src/modules/ai) ──────────────────────────────────────────────────
# Read by: openai.service.ts, ai.controller.ts
#
# AI_ENABLED — master switch for all /ai/* routes.
#   Default in code: "true". Set to "false" to return 503 Service Unavailable.
AI_ENABLED=true
#
# OPENAI_API_KEY — OpenAI API key for Chat Completions.
#   Default in code: empty string.
#   If empty (or AI_ENABLED=false), isConfigured() is false and feature services
#   use local heuristic fallbacks (recommend / concierge / strategy still work).
#   Hệ thống sẽ dùng heuristic fallback nếu không có OPENAI_API_KEY.
OPENAI_API_KEY=
#
# OPENAI_MODEL — model id passed to OpenAI chat/completions.
#   Default in code: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
#
# OPENAI_BASE_URL — OpenAI-compatible API base (no trailing path beyond /v1).
#   Default in code: https://api.openai.com/v1
#   Override only for Azure/proxy/compatible gateways.
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Frontend ──────────────────────────────────────────────────────────────────
# REQUIRED in production — set to your deployed frontend URL, e.g. https://app.auraspa.vn
# In development falls back to http://localhost:3000 if omitted
FRONTEND_URL=http://localhost:3000
